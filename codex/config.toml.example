# codex/config.toml.example
# MCP server configuration for b-agent-skills (Codex edition)
#
# Copy this file to one of:
#   ~/.codex/config.toml          (user-level — applies to all projects)
#   <project-root>/codex.toml     (project-level — applies to this project only)
#
# Fill in your API keys, then verify with: codex mcp list
# All 5 MCPs should show as connected before running skills that require them.
#
# Skill → MCP dependency map:
#   brave-search  : b-quick-search (req), b-news (req), b-research (req),
#                   b-debug (opt), b-analyze (opt)
#   firecrawl     : b-research (req), b-docs (opt), b-news (opt)
#   context7      : b-docs (req), b-research (opt)
#   sequential-thinking : b-plan (req), b-debug (req), b-review (opt),
#                         b-analyze (opt), b-research (opt)
#   jcodemunch    : b-analyze (req), b-plan (opt), b-debug (opt), b-review (opt)

# ── brave-search ─────────────────────────────────────────────────────────────
# Transport: stdio
# Get your API key at: https://brave.com/search/api/
[mcpServers.brave-search]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-brave-search"]

[mcpServers.brave-search.env]
BRAVE_API_KEY = "YOUR_BRAVE_API_KEY_HERE"

# ── firecrawl ─────────────────────────────────────────────────────────────────
# Transport: stdio
# Get your API key at: https://firecrawl.dev/
#
# ⚠️  Known limitation (Codex cloud sandbox):
# Codex cloud sandbox may block outbound HTTP connections to Firecrawl's API.
# If firecrawl tools return connection errors, run Codex locally or set up a
# local Firecrawl proxy. See codex/README.md#known-limitations for details.
# Skills that require firecrawl (b-research, b-docs) will fail without it.
[mcpServers.firecrawl]
command = "npx"
args = ["-y", "firecrawl-mcp"]

[mcpServers.firecrawl.env]
FIRECRAWL_API_KEY = "YOUR_FIRECRAWL_API_KEY_HERE"

# ── context7 ──────────────────────────────────────────────────────────────────
# Transport: streamable HTTP (no API key required for public access)
# context7 provides version-accurate library documentation.
[mcpServers.context7]
type = "http"
url = "https://mcp.context7.com/mcp"

# ── sequential-thinking ───────────────────────────────────────────────────────
# Transport: stdio
# Provides structured reasoning and task decomposition.
[mcpServers.sequential-thinking]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-sequential-thinking"]

# ── jcodemunch ────────────────────────────────────────────────────────────────
# Transport: stdio (local analysis server)
#
# ⚠️  Known limitation (Codex cloud sandbox):
# jcodemunch performs local codebase indexing and may not function correctly in
# Codex cloud sandbox environments (no filesystem access to your project).
# Run Codex locally for full jcodemunch support.
# All skills that use jcodemunch degrade gracefully to Glob/Read fallback when
# unavailable — mark jcodemunch as optional in cloud environments.
[mcpServers.jcodemunch]
command = "npx"
args = ["-y", "jcodemunch-mcp"]
# If jcodemunch requires an API key, add it here:
# [mcpServers.jcodemunch.env]
# JCODEMUNCH_API_KEY = "YOUR_KEY_HERE"
